{
  "openapi": "3.1.0",
  "info": {
    "title": "Relayer API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "paths": {
    "/nonce": {
      "get": {
        "operationId": "getNonce",
        "summary": "Get Deposit Wallet nonce",
        "parameters": [
          {
            "name": "address",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^0x[a-fA-F0-9]{40}$"
            }
          },
          {
            "name": "type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["WALLET-CREATE", "WALLET"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Current nonce.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NonceResponse"
                }
              }
            }
          }
        }
      }
    },
    "/submit": {
      "post": {
        "operationId": "submitTransaction",
        "summary": "Submit Deposit Wallet transaction",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RelayerSubmitRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction accepted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmitResponse"
                }
              }
            }
          }
        }
      }
    },
    "/submit/wallet": {
      "post": {
        "operationId": "submitPublicWalletTransaction",
        "summary": "Submit public Deposit Wallet transaction",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RelayerSubmitRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction accepted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmitResponse"
                }
              }
            }
          }
        }
      }
    },
    "/transaction": {
      "get": {
        "operationId": "getTransaction",
        "summary": "Get transaction by id",
        "description": "Public polling endpoint for a previously submitted relayer transaction id.",
        "security": [],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Matching transactions.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RelayerTransaction"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/transactions": {
      "get": {
        "operationId": "listTransactions",
        "summary": "List caller transactions",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Caller transactions.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RelayerTransaction"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/deployed": {
      "get": {
        "operationId": "getDeployed",
        "summary": "Check contract deployment",
        "parameters": [
          {
            "name": "address",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^0x[a-fA-F0-9]{40}$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deployment status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeployedResponse"
                }
              }
            }
          }
        }
      }
    },
    "/operations/approve": {
      "post": {
        "operationId": "approveToken",
        "summary": "Approve ERC20 spender",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApproveRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Approval submitted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OnchainExecutionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/operations/set-approval": {
      "post": {
        "operationId": "setApprovalForAll",
        "summary": "Set Conditional Tokens approval",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetApprovalRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Approval submitted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OnchainExecutionResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "KUEST-API-KEY"
      }
    },
    "schemas": {
      "Address": {
        "type": "string",
        "pattern": "^0x[a-fA-F0-9]{40}$"
      },
      "Hex": {
        "type": "string",
        "pattern": "^0x[a-fA-F0-9]*$"
      },
      "NonceResponse": {
        "type": "object",
        "required": ["nonce"],
        "properties": {
          "nonce": {
            "type": "string"
          }
        }
      },
      "DepositWalletCall": {
        "type": "object",
        "required": ["target", "value", "data"],
        "properties": {
          "target": {
            "$ref": "#/components/schemas/Address"
          },
          "value": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/Hex"
          }
        }
      },
      "DepositWalletParams": {
        "type": "object",
        "required": ["depositWallet", "deadline", "calls"],
        "properties": {
          "depositWallet": {
            "$ref": "#/components/schemas/Address"
          },
          "deadline": {
            "type": "string"
          },
          "calls": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/components/schemas/DepositWalletCall"
            }
          }
        }
      },
      "RelayerSubmitRequest": {
        "type": "object",
        "required": ["type", "from", "to", "data", "value", "signature", "signatureParams"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["WALLET-CREATE", "WALLET"]
          },
          "from": {
            "$ref": "#/components/schemas/Address"
          },
          "to": {
            "$ref": "#/components/schemas/Address"
          },
          "data": {
            "$ref": "#/components/schemas/Hex"
          },
          "value": {
            "type": "string",
            "default": "0"
          },
          "nonce": {
            "type": "string"
          },
          "signature": {
            "$ref": "#/components/schemas/Hex"
          },
          "signatureParams": {
            "type": "object",
            "properties": {
              "depositWalletParams": {
                "$ref": "#/components/schemas/DepositWalletParams"
              }
            }
          },
          "depositWalletParams": {
            "$ref": "#/components/schemas/DepositWalletParams"
          },
          "metadata": {
            "type": "string"
          }
        }
      },
      "SubmitResponse": {
        "type": "object",
        "required": ["transactionID", "state"],
        "properties": {
          "transactionID": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "transactionHash": {
            "type": "string"
          },
          "hash": {
            "type": "string"
          }
        }
      },
      "RelayerTransaction": {
        "type": "object",
        "properties": {
          "transactionID": {
            "type": "string"
          },
          "transactionHash": {
            "type": "string"
          },
          "from": {
            "$ref": "#/components/schemas/Address"
          },
          "to": {
            "$ref": "#/components/schemas/Address"
          },
          "walletAddress": {
            "$ref": "#/components/schemas/Address"
          },
          "data": {
            "$ref": "#/components/schemas/Hex"
          },
          "nonce": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "failureReason": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["WALLET-CREATE", "WALLET"]
          },
          "metadata": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "DeployedResponse": {
        "type": "object",
        "required": ["deployed"],
        "properties": {
          "deployed": {
            "type": "boolean"
          }
        }
      },
      "ApproveRequest": {
        "type": "object",
        "required": ["spender", "amount"],
        "properties": {
          "token": {
            "$ref": "#/components/schemas/Address"
          },
          "spender": {
            "$ref": "#/components/schemas/Address"
          },
          "amount": {
            "type": "string"
          }
        }
      },
      "SetApprovalRequest": {
        "type": "object",
        "required": ["operator", "approved"],
        "properties": {
          "operator": {
            "$ref": "#/components/schemas/Address"
          },
          "approved": {
            "type": "boolean"
          },
          "contract": {
            "$ref": "#/components/schemas/Address"
          }
        }
      },
      "OnchainExecutionResponse": {
        "type": "object",
        "required": ["txHash", "confirmations"],
        "properties": {
          "txHash": {
            "type": "string"
          },
          "confirmations": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
